FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue alpha.air 1
    volScalarFieldValue alpha.siliconoil 0
);

regions
(
    boxToCell
    {
        box (-0.015 -0.025 -0.015) (0.015 -0.005 0.015);
        fieldValues
        (
            volScalarFieldValue alpha.siliconoil 1
        );
    }
);


