FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alpha.siliconoil;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    tank
    {
        type            constantAlphaContactAngle;
        theta0          5;
        limit           gradient;
        value           uniform 0;
    }

    staticsurface
    {
        type            constantAlphaContactAngle;
        theta0          30;
        limit           gradient;
        value           uniform 0;
    }
 
    openatmosphere
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }

    defaultFaces
    {
        type            empty;
    }
}

// ************************************************************************* //
